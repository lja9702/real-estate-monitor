# myhouse 비밀값 — 이 파일을 .env 로 복사해 채우세요(`cp .env.example .env` 후 `chmod 600 .env`).
# .env 는 .gitignore 대상이라 커밋되지 않습니다.

# ── 텔레그램 봇/알림 (선택) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=            # 쉼표 복수 가능: 111,222
TELEGRAM_ALLOWLIST=         # 봇 명령 허용 chat_id(운영자 앵커). 비우면 전체 허용
TELEGRAM_JOIN_CODE=         # 텔레그램 초대코드 — /join <코드> 로 셀프 등록

# ── 웹 대시보드 초대코드 게이트 (지인 공개 시) ─────────────────────────────
# 웹 게이트는 위 TELEGRAM_JOIN_CODE 를 그대로 초대코드로 받습니다(텔레그램 /join 과 동일 코드).
#   → TELEGRAM_JOIN_CODE 만 설정해도 웹 게이트가 켜집니다. 이때 로컬 대시보드도 코드를 묻습니다.
# WEB_INVITE_CODES 는 웹 전용 추가 코드(선택). 둘 다 비면 게이트 off(전체 허용).
WEB_INVITE_CODES=           # (선택) 웹 전용 추가 초대코드(쉼표 복수): spring2026,namsan77
SESSION_SECRET=            # 쿠키 서명 키(랜덤 권장): `python -c "import secrets;print(secrets.token_urlsafe(32))"`
# localhost(루프백) 접속은 코드 없이 통과(운영자 로컬 편의). 클라우드/터널은 프록시 헤더로 항상 차단됨.
# 로컬도 코드를 요구하려면 false 로:
GATE_LOCAL_BYPASS=true

# ── 클라우드 DB 동기화 (Cloudflare R2 — 배포 시) ───────────────────────────
# 맥은 `myhouse sync-push` 로 DB 스냅샷을 R2 에 올리고, 클라우드(읽기 전용)가 받아 서빙.
# 하나라도 비면 동기화 비활성(로컬 단독 사용엔 불필요).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# R2_DB_KEY=myhouse.db            # (선택) 버킷 내 오브젝트 키

# ── 기타 (선택) ───────────────────────────────────────────────────────────
NAVER_MAP_CLIENT_ID=        # 지도 타일용(없어도 동작)
